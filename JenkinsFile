pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK11'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        APP_NAME = "ecommerce-app"
        REPO_URL = "https://github.com/your-repo/ecommerce-app.git"

        NEXUS_URL = "http://your-nexus-url/repository/maven-releases/"
        NEXUS_CREDENTIALS_ID = "nexus-credentials"

        SSH_CREDENTIALS_ID = "ssh-key"
        DEPLOY_SERVER = "user@your-server"

        ARTIFACT_VERSION = "1.0.${BUILD_NUMBER}"
        SONAR_PROJECT_KEY = "ecommerce-app"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Code') {
            steps {
                git branch: 'main', url: "${REPO_URL}"
            }
        }

        stage('Build + Test + SonarQube') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh """
                    mvn clean verify sonar:sonar \
                    -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                    -Dsonar.projectName=${APP_NAME}
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Artifact') {
            steps {
                sh "mvn package -DskipTests"
                sh "ls -l target/"
            }
        }

        stage('Upload to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${NEXUS_CREDENTIALS_ID}",
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh """
                    test -f target/${APP_NAME}.jar || exit 1

                    curl -u $NEXUS_USER:$NEXUS_PASS \
                    --upload-file target/${APP_NAME}.jar \
                    ${NEXUS_URL}${APP_NAME}-${ARTIFACT_VERSION}.jar
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([sshUserPrivateKey(
                    credentialsId: "${SSH_CREDENTIALS_ID}",
                    keyFileVariable: 'SSH_KEY',
                    usernameVariable: 'SSH_USER'
                )]) {

                    sh """
                    ssh -i $SSH_KEY -o StrictHostKeyChecking=no $SSH_USER@${DEPLOY_SERVER.split('@')[1]} << EOF

                    set -e

                    echo "Stopping existing app..."
                    pkill -f ${APP_NAME} || true

                    echo "Creating directory..."
                    mkdir -p /opt/${APP_NAME}

                    echo "Downloading artifact from Nexus..."
                    curl -o /opt/${APP_NAME}/${APP_NAME}.jar \
                    ${NEXUS_URL}${APP_NAME}-${ARTIFACT_VERSION}.jar

                    echo "Starting application..."
                    nohup java -jar /opt/${APP_NAME}/${APP_NAME}.jar > app.log 2>&1 &

                    echo "Waiting for app to start..."
                    sleep 10

                    echo "Checking application..."
                    ps -ef | grep ${APP_NAME} | grep -v grep

                    echo "Deployment successful"

EOF
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ CI/CD Pipeline completed successfully"
        }
        failure {
            echo "❌ Pipeline failed"
        }
        always {
            cleanWs()
        }
    }
}
